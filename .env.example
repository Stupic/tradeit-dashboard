# ── 복사해서 .env.local 로 저장하세요 ────────────────────────────
# DB는 AWS RSD(외부 비공개)이며, 사내 중앙 호스트(192.168.0.12)가
# SSH 터널을 유지합니다. 각 PC는 그 호스트로 붙기만 하면 됩니다.

# ▶ 다른 PC(팀원): 중앙 호스트 IP 사용
DB_HOST=192.168.0.12
# ▶ 중앙 호스트 본인 PC에서 실행할 때만: DB_HOST=localhost

DB_PORT=13306
DB_NAME=taas-v2
DB_USER=admin
DB_PASSWORD=__ASK_TEAM__   # 실제 값은 팀에 문의 (git에 커밋 금지)

# 집계 기준 타임존 (오늘/이번달 경계)
DB_TIMEZONE=+09:00
